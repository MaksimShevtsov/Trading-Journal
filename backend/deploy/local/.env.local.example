# Local Development Environment
APP_ENV=local
DEBUG=true
LOG_LEVEL=DEBUG

# PostgreSQL Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=trading_journal
DB_USER=postgres
DB_PASSWORD=postgres

# Admin Panel
ADMIN_ENABLED=true
ADMIN_SESSION_SECRET=dev-admin-secret

# Encryption (pgcrypto placeholder)
ENCRYPTION_KEY=dev-only-key-never-use-in-production
